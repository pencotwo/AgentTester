{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ListAgent Test Suite",
  "version": "0.1.0",
  "identifier": "com.listagent.testsuite",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ListAgent Test Suite",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
